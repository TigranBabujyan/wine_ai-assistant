# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Supabase (find in your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Encryption secret for API keys stored in DB
# Generate with: openssl rand -base64 32
DB_ENCRYPTION_SECRET=your-strong-random-secret-here

# Optional: Anthropic key for landing page demo (rate-limited, unauthenticated)
# If not set, demo search is disabled
ANTHROPIC_API_KEY=
